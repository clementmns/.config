[
  {
    "context": "VimControl && vim_mode == normal",
    "bindings": {
      // -- popups commands
      "space space": "file_finder::Toggle",
      // -- panes commands
      "space w": "pane::CloseActiveItem",
      "space s": "pane::SplitDown",
      "space v": "pane::SplitRight",
      // -- file commands
      "space f s": "project_panel::ToggleFocus",
      // -- outlines commands
      "space o": "outline::Toggle",
      // -- git commands
      "space g b": "git::Branch",
      "space g g": "git_panel::ToggleFocus",
      "space g a": "git::Add",
      "space g c": "git::Commit",
      "space g p": "git::Push",
      "space g f": "git::Fetch",
      "space g l": "git::Pull",
      // -- terminal commands
      "space t": "terminal_panel::ToggleFocus",
      // -- pane commands
      "space j": "workspace::ActivatePaneDown",
      "space k": "workspace::ActivatePaneUp",
      "space h": "workspace::ActivatePaneLeft",
      "space l": "workspace::ActivatePaneRight",
    },
  },
  {
    "context": "ProjectPanel && not_editing",
    "bindings": {
      "a": "project_panel::NewFile",
      "d": "project_panel::Delete",
      "r": "project_panel::Rename",
    },
  },
]
